{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NEXUS Phase 1 Shard Schema",
  "version": "1.0.0",
  "type": "object",
  "required": ["shard_id", "shard_type", "producer", "created_at_utc", "data"],
  "properties": {
    "shard_id": {
      "type": "string",
      "description": "Deterministic UUID v5 or hash-based ID"
    },
    "shard_type": {
      "type": "string",
      "enum": ["gig_demand_signal", "driver_status", "payout_signal", "route_score"],
      "description": "Only gig_demand_signal is required for MVP"
    },
    "producer": {
      "type": "string",
      "description": "Name of extractor, e.g., 'nexus_gig_demand_extractor_v1'"
    },
    "data": {
      "type": "object",
      "description": "Payload; schema depends on shard_type"
    },
    "lineage": {
      "type": "object",
      "description": "Optional lineage info from lineage engine",
      "properties": {
        "parent_shards": { "type": "array", "items": { "type": "string" } },
        "created_by": { "type": "string" },
        "transform": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
